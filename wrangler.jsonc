{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cloudflare-rancher",
  "main": "src/index.ts",
  "compatibility_date": "2026-03-31",

  // Replace with your Cloudflare account ID (32-char hex from CF dashboard)
  // "account_id": "YOUR_ACCOUNT_ID_HERE",

  "assets": {
    "directory": "./public",
    "binding": "ASSETS"
  },

  // Route — serve this Worker at rancher.everlightos.com
  "routes": [
    {
      "pattern": "rancher.everlightos.com/*",
      "zone_name": "everlightos.com"
    }
  ],

  // Worker secrets (set via: wrangler secret put ANTHROPIC_API_KEY)
  // Required:  ANTHROPIC_API_KEY
  // Optional:  ANTHROPIC_MODEL, ALLOWED_ORIGIN

  "observability": {
    "enabled": true
  }
}
